# Database
DATABASE_URL="file:./dev.db"

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Session secret (générer une chaîne aléatoire sécurisée)
SESSION_SECRET=your-random-secret-key-at-least-32-characters

# URL de l'application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe Keys (à récupérer depuis https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Price IDs (à créer dans https://dashboard.stripe.com/products)
STRIPE_PRICE_ID_SOLO_MONTHLY=price_your_solo_monthly_id
STRIPE_PRICE_ID_SOLO_YEARLY=price_your_solo_yearly_id
STRIPE_PRICE_ID_FAMILY_MONTHLY=price_your_family_monthly_id
STRIPE_PRICE_ID_FAMILY_YEARLY=price_your_family_yearly_id
STRIPE_PRICE_ID_PRO_MONTHLY=price_your_pro_monthly_id
STRIPE_PRICE_ID_PRO_YEARLY=price_your_pro_yearly_id

# Stripe Webhook Secret (pour le webhook en local: stripe listen --forward-to localhost:3300/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email Provider (Resend) - Obtenez votre clé sur https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=onboarding@resend.dev
CONTACT_EMAIL=contact@yourcompany.com
